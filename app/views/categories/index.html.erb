<div class="flex justify-between items-center mb-6">
  <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Categorias</h1>
  <%= link_to "Nova Categoria", new_category_path, class: "bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700" %>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
  <div>
    <h2 class="text-lg font-semibold mb-4 text-red-600 dark:text-red-400">Despesas</h2>
    <div class="space-y-2">
      <% @categories.expenses.roots.each do |category| %>
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-4 border-l-4 dark:border-gray-600" style="border-color: <%= category.color %>">
          <div class="flex justify-between items-center">
            <div>
              <span class="font-medium text-gray-900 dark:text-white"><%= category.name %></span>
              <% if category.children.any? %>
                <div class="ml-4 mt-2 space-y-1">
                  <% category.children.each do |child| %>
                    <div class="flex justify-between items-center text-sm">
                      <span class="text-gray-600 dark:text-gray-400"><%= child.name %></span>
                      <div class="flex gap-2">
                        <%= link_to "Editar", edit_category_path(child), class: "text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300" %>
                        <%= link_to "Excluir", child, method: :delete, data: { confirm: "Tem certeza?" }, class: "text-red-600 dark:text-red-400 hover:text-red-800 dark:hover:text-red-300" %>
                      </div>
                    </div>
                  <% end %>
                </div>
              <% end %>
            </div>
            <div class="flex gap-2">
              <%= link_to "+ Sub", new_category_path(parent_id: category.id), class: "text-sm text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300" %>
              <%= link_to "Editar", edit_category_path(category), class: "text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300" %>
              <%= link_to "Excluir", category, method: :delete, data: { confirm: "Tem certeza?" }, class: "text-red-600 dark:text-red-400 hover:text-red-800 dark:hover:text-red-300" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
    <% if @categories.expenses.empty? %>
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-8 text-center text-gray-500 dark:text-gray-400">
        Nenhuma categoria de despesa.
      </div>
    <% end %>
  </div>

  <div>
    <h2 class="text-lg font-semibold mb-4 text-green-600 dark:text-green-400">Receitas</h2>
    <div class="space-y-2">
      <% @categories.incomes.roots.each do |category| %>
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-4 border-l-4 dark:border-gray-600" style="border-color: <%= category.color %>">
          <div class="flex justify-between items-center">
            <div>
              <span class="font-medium text-gray-900 dark:text-white"><%= category.name %></span>
              <% if category.children.any? %>
                <div class="ml-4 mt-2 space-y-1">
                  <% category.children.each do |child| %>
                    <div class="flex justify-between items-center text-sm">
                      <span class="text-gray-600 dark:text-gray-400"><%= child.name %></span>
                      <div class="flex gap-2">
                        <%= link_to "Editar", edit_category_path(child), class: "text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300" %>
                        <%= link_to "Excluir", child, method: :delete, data: { confirm: "Tem certeza?" }, class: "text-red-600 dark:text-red-400 hover:text-red-800 dark:hover:text-red-300" %>
                      </div>
                    </div>
                  <% end %>
                </div>
              <% end %>
            </div>
            <div class="flex gap-2">
              <%= link_to "+ Sub", new_category_path(parent_id: category.id), class: "text-sm text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300" %>
              <%= link_to "Editar", edit_category_path(category), class: "text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300" %>
              <%= link_to "Excluir", category, method: :delete, data: { confirm: "Tem certeza?" }, class: "text-red-600 dark:text-red-400 hover:text-red-800 dark:hover:text-red-300" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
    <% if @categories.incomes.empty? %>
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-8 text-center text-gray-500 dark:text-gray-400">
        Nenhuma categoria de receita.
      </div>
    <% end %>
  </div>
</div>
