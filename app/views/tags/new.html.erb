<div class="max-w-lg mx-auto">
  <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-900 mb-6">Nova Tag</h1>

  <%= form_with model: @tag, class: "bg-white dark:bg-gray-800 rounded-lg shadow p-6" do |f| %>
    <% if @tag.errors.any? %>
      <div class="bg-red-100 dark:bg-red-900/50 border border-red-400 dark:border-red-600 text-red-700 dark:text-red-300 px-4 py-3 rounded mb-4">
        <h2 class="font-bold"><%= pluralize(@tag.errors.count, "erro") %> impediu esta tag de ser salva:</h2>
        <ul class="list-disc list-inside">
          <% @tag.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="mb-6">
      <%= f.label :name, "Nome", class: "block text-sm font-medium text-gray-800 dark:text-gray-300 mb-1" %>
      <%= f.text_field :name, class: "w-full border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-900 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500", required: true %>
    </div>

    <div class="flex gap-3">
      <%= f.submit "Criar Tag", class: "bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 cursor-pointer" %>
      <%= link_to "Cancelar", tags_path, class: "bg-gray-300 dark:bg-gray-600 dark:text-gray-900 hover:bg-gray-400 text-gray-800 px-4 py-2 rounded-lg" %>
    </div>
  <% end %>
</div>
