<div class="flex justify-between items-center mb-6">
  <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Dashboard</h1>
  <%= link_to "Nova Transação", new_transaction_path, class: "bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg" %>
</div>

<div class="mb-8">
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
      <div class="text-sm text-gray-500 dark:text-gray-400 mb-1">Saldo Total</div>
      <div class="text-2xl font-bold <%= @total_balance >= 0 ? 'text-green-600 dark:text-green-400' : 'text-red-600 dark:text-red-400' %>">
        <%= number_to_currency(@total_balance) %>
      </div>
    </div>
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
      <div class="text-sm text-gray-500 dark:text-gray-400 mb-1">Receitas do Mês</div>
      <div class="text-2xl font-bold text-green-600 dark:text-green-400">
        <%= number_to_currency(@monthly_income) %>
      </div>
    </div>
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
      <div class="text-sm text-gray-500 dark:text-gray-400 mb-1">Despesas do Mês</div>
      <div class="text-2xl font-bold text-red-600 dark:text-red-400">
        <%= number_to_currency(@monthly_expense) %>
      </div>
    </div>
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
      <div class="text-sm text-gray-500 dark:text-gray-400 mb-1">Balanço do Mês</div>
      <div class="text-2xl font-bold <%= @monthly_balance >= 0 ? 'text-green-600 dark:text-green-400' : 'text-red-600 dark:text-red-400' %>">
        <%= number_to_currency(@monthly_balance) %>
      </div>
    </div>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
    <div class="flex justify-between items-center mb-4">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Contas</h2>
      <%= link_to "Gerenciar", accounts_path, class: "text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 text-sm" %>
    </div>
    <% if @accounts.any? %>
      <div class="space-y-3">
        <% @accounts.each do |account| %>
          <div class="flex justify-between items-center p-3 bg-gray-50 dark:bg-gray-700 rounded-lg">
            <div class="flex items-center gap-3">
              <span class="w-3 h-3 rounded-full" style="background-color: <%= account.color %>"></span>
              <span class="font-medium text-gray-900 dark:text-white"><%= account.name %></span>
            </div>
            <span class="font-medium <%= account.balance >= 0 ? 'text-green-600 dark:text-green-400' : 'text-red-600 dark:text-red-400' %>">
              <%= number_to_currency(account.balance) %>
            </span>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center text-gray-500 dark:text-gray-400 py-4">
        Nenhuma conta cadastrada.
        <%= link_to "Criar conta", new_account_path, class: "text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300" %>
      </div>
    <% end %>
  </div>

  <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
    <div class="flex justify-between items-center mb-4">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Maiores Despesas do Mês</h2>
      <%= link_to "Ver Todas", transactions_path, class: "text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 text-sm" %>
    </div>
    <% if @top_expenses.any? %>
      <div class="space-y-3">
        <% @top_expenses.each do |category_name, amount| %>
          <div class="flex justify-between items-center">
            <span class="text-gray-700 dark:text-gray-300"><%= category_name %></span>
            <span class="font-medium text-red-600 dark:text-red-400">-<%= number_to_currency(amount) %></span>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center text-gray-500 dark:text-gray-400 py-4">
        Nenhuma despesa registrada este mês.
      </div>
    <% end %>
  </div>
</div>

<div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
  <div class="flex justify-between items-center mb-4">
    <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Últimas Transações</h2>
    <%= link_to "Ver Todas", transactions_path, class: "text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 text-sm" %>
  </div>
  <% if @recent_transactions.any? %>
    <div class="overflow-hidden">
      <table class="w-full">
        <thead class="bg-gray-50 dark:bg-gray-700">
          <tr>
            <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 dark:text-gray-300">Data</th>
            <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 dark:text-gray-300">Descrição</th>
            <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 dark:text-gray-300">Categoria</th>
            <th class="px-4 py-2 text-right text-xs font-medium text-gray-500 dark:text-gray-300">Valor</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
          <% @recent_transactions.each do |transaction| %>
            <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
              <td class="px-4 py-2 text-sm text-gray-900 dark:text-gray-100"><%= l(transaction.date) %></td>
              <td class="px-4 py-2 text-sm text-gray-900 dark:text-gray-100"><%= transaction.description.presence || "-" %></td>
              <td class="px-4 py-2 text-sm text-gray-900 dark:text-gray-100"><%= transaction.category.name %></td>
              <td class="px-4 py-2 text-sm text-right font-medium <%= transaction.transaction_type_expense? ? 'text-red-600 dark:text-red-400' : 'text-green-600 dark:text-green-400' %>">
                <%= number_to_currency(transaction.signed_amount) %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="text-center text-gray-500 dark:text-gray-400 py-4">
      Nenhuma transação registrada.
      <%= link_to "Registrar transação", new_transaction_path, class: "text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300" %>
    </div>
  <% end %>
</div>
