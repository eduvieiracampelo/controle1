<div class="flex justify-between items-center mb-6">
  <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Contas</h1>
  <%= link_to "Nova Conta", new_account_path, class: "bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700" %>
</div>

<div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6 mb-6">
  <div class="flex justify-between items-center">
    <span class="text-gray-600 dark:text-gray-400">Saldo Total</span>
    <span class="text-2xl font-bold <%= @total_balance >= 0 ? 'text-green-600 dark:text-green-400' : 'text-red-600 dark:text-red-400' %>">
      <%= number_to_currency(@total_balance) %>
    </span>
  </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
  <% @accounts.each do |account| %>
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6 border-l-4 dark:border-gray-600" style="border-color: <%= account.color %>">
      <div class="flex justify-between items-start mb-4">
        <div>
          <h3 class="font-semibold text-lg text-gray-900 dark:text-white"><%= account.name %></h3>
          <span class="text-sm text-gray-500 dark:text-gray-400"><%= account.display_type %></span>
        </div>
        <div class="flex gap-2">
          <%= link_to "Editar", edit_account_path(account), class: "text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 text-sm" %>
          <%= link_to "Excluir", account, method: :delete, data: { confirm: "Tem certeza?" }, class: "text-red-600 dark:text-red-400 hover:text-red-800 dark:hover:text-red-300 text-sm" %>
        </div>
      </div>
      <div class="text-2xl font-bold <%= account.balance >= 0 ? 'text-green-600 dark:text-green-400' : 'text-red-600 dark:text-red-400' %>">
        <%= number_to_currency(account.balance) %>
      </div>
      <% if account.account_type_credit_card? && account.credit_limit > 0 %>
        <div class="mt-2 text-sm text-gray-500 dark:text-gray-400">
          Limite: <%= number_to_currency(account.credit_limit) %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>

<% if @accounts.empty? %>
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-8 text-center text-gray-500 dark:text-gray-400">
    Nenhuma conta cadastrada. <%= link_to "Clique aqui", new_account_path, class: "text-blue-600 dark:text-blue-400" %> para criar a primeira.
  </div>
<% end %>
