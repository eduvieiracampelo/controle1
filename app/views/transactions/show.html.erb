<div class="flex justify-between items-center mb-6">
  <h1 class="text-2xl font-bold text-gray-900 dark:text-gray-900">Transação</h1>
  <div class="flex gap-2">
    <%= link_to "Editar", edit_transaction_path(@transaction), class: "bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700" %>
    <%= link_to "Voltar", transactions_path, class: "bg-gray-300 dark:bg-gray-600 dark:text-gray-900 hover:bg-gray-400 text-gray-800 px-4 py-2 rounded-lg" %>
  </div>
</div>

<div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
  <dl class="grid grid-cols-2 gap-4">
    <div>
      <dt class="text-sm text-gray-500 dark:text-gray-400">Tipo</dt>
      <dd class="font-medium text-gray-900 dark:text-gray-900"><%= @transaction.display_type %></dd>
    </div>
    <div>
      <dt class="text-sm text-gray-500 dark:text-gray-400">Valor</dt>
      <dd class="font-medium <%= @transaction.transaction_type_expense? ? 'text-red-600 dark:text-red-400' : 'text-green-600 dark:text-green-400' %>">
        <%= number_to_currency(@transaction.amount) %>
      </dd>
    </div>
    <div>
      <dt class="text-sm text-gray-500 dark:text-gray-400">Data</dt>
      <dd class="font-medium text-gray-900 dark:text-gray-900"><%= l(@transaction.date) %></dd>
    </div>
    <div>
      <dt class="text-sm text-gray-500 dark:text-gray-400">Status</dt>
      <dd class="font-medium <%= @transaction.paid ? 'text-green-600 dark:text-green-400' : 'text-yellow-600 dark:text-yellow-400' %>">
        <%= @transaction.paid ? "Pago" : "Pendente" %>
      </dd>
    </div>
    <div>
      <dt class="text-sm text-gray-500 dark:text-gray-400">Conta</dt>
      <dd class="font-medium text-gray-900 dark:text-gray-900"><%= @transaction.account.name %></dd>
    </div>
    <div>
      <dt class="text-sm text-gray-500 dark:text-gray-400">Categoria</dt>
      <dd class="font-medium text-gray-900 dark:text-gray-900"><%= @transaction.category.name %></dd>
    </div>
    <div class="col-span-2">
      <dt class="text-sm text-gray-500 dark:text-gray-400">Descrição</dt>
      <dd class="font-medium text-gray-900 dark:text-gray-900"><%= @transaction.description.presence || "-" %></dd>
    </div>
    <% if @transaction.tags.any? %>
      <div class="col-span-2">
        <dt class="text-sm text-gray-500 dark:text-gray-400 mb-2">Tags</dt>
        <dd class="flex gap-2">
          <% @transaction.tags.each do |tag| %>
            <span class="inline-flex items-center px-2 py-1 rounded bg-gray-100 dark:bg-gray-700 text-sm text-gray-900 dark:text-gray-100"><%= tag.name %></span>
          <% end %>
        </dd>
      </div>
    <% end %>
  </dl>
</div>
