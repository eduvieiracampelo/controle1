<!DOCTYPE html>
<html class="dark" id="html-root">
  <head>
    <title><%= content_for(:title) || "Controle Financeiro" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Controle Financeiro">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <script>
      (function() {
        const theme = localStorage.getItem('theme');
        if (theme === 'light') {
          document.getElementById('html-root').classList.remove('dark');
        }
      })();
    </script>

    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <style id="dark-mode-styles" media="all">
      html:not(.dark) body { background-color: #f3f4f6; }
      
      html.dark body { background-color: #111827 !important; }
      html.dark .bg-white { background-color: #1f2937 !important; }
      html.dark .bg-gray-50 { background-color: #374151 !important; }
      html.dark .bg-gray-100 { background-color: #374151 !important; }
      html.dark .bg-gray-800 { background-color: #1f2937 !important; }
      html.dark .bg-gray-700 { background-color: #374151 !important; }
      
      html.dark .text-gray-500 { color: #9ca3af !important; }
      html.dark .text-gray-600 { color: #d1d5db !important; }
      html.dark .text-gray-700 { color: #e5e7eb !important; }
      html.dark .text-gray-800 { color: #f3f4f6 !important; }
      html.dark .text-gray-900 { color: #f9fafb !important; }
      html.dark .text-white { color: #ffffff !important; }
      
      html.dark .border-gray-200 { border-color: #4b5563 !important; }
      html.dark .border-gray-300 { border-color: #6b7280 !important; }
      html.dark .border-gray-600 { border-color: #6b7280 !important; }
      html.dark .divide-gray-200 { border-color: #4b5563 !important; }
      
      html.dark table { color: #f3f4f6 !important; }
      html.dark thead { background-color: #374151 !important; }
      html.dark th { color: #d1d5db !important; }
      html.dark tbody tr:hover { background-color: #374151 !important; }
      
      html.dark input, 
      html.dark select, 
      html.dark textarea {
        background-color: #374151 !important;
        border-color: #6b7280 !important;
        color: #f3f4f6 !important;
      }
    </style>

    <script>
      function toggleTheme() {
        const html = document.getElementById('html-root');
        const isDark = html.classList.toggle("dark");
        localStorage.setItem("theme", isDark ? "dark" : "light");
        
        const icon = document.getElementById('theme-icon');
        if (isDark) {
          icon.innerHTML = '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>';
        } else {
          icon.innerHTML = '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path></svg>';
        }
      }
    </script>

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="pt-20">
    <nav class="fixed top-0 left-0 right-0 z-50 bg-white dark:bg-gray-800 shadow mb-8">
      <div class="max-w-7xl mx-auto px-4">
        <div class="flex justify-between h-16">
          <div class="flex items-center">
            <%= link_to "Controle Financeiro", root_path, class: "text-xl font-bold text-gray-800 dark:text-white" %>
          </div>
          <div class="flex items-center justify-center space-x-4">
            <%= link_to "Dashboard", root_path, class: "text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white px-3 py-2 rounded-md text-sm font-medium" %>
            <%= link_to "Contas", accounts_path, class: "text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white px-3 py-2 rounded-md text-sm font-medium" %>
            <%= link_to "Transações", transactions_path, class: "text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white px-3 py-2 rounded-md text-sm font-medium" %>
            <%= link_to "Categorias", categories_and_tags_path, class: "text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white px-3 py-2 rounded-md text-sm font-medium" %>
            <%= link_to "Backup", backup_path, class: "text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white px-3 py-2 rounded-md text-sm font-medium" %>
          </div>
          <div class="flex items-center">
            <button onclick="toggleTheme()" class="p-2 rounded-lg bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors">
              <span id="theme-icon">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
                </svg>
              </span>
            </button>
          </div>
        </div>
      </div>
    </nav>

    <main class="max-w-7xl mx-auto px-4 pb-8">
      <% if notice %>
        <div class="bg-green-100 dark:bg-green-900 border border-green-400 dark:border-green-600 text-green-700 dark:text-green-300 px-4 py-3 rounded mb-4">
          <%= notice %>
        </div>
      <% end %>
      <% if alert %>
        <div class="bg-red-100 dark:bg-red-900 border border-red-400 dark:border-red-600 text-red-700 dark:text-red-300 px-4 py-3 rounded mb-4">
          <%= alert %>
        </div>
      <% end %>
      <%= yield %>
    </main>
  </body>
</html>
