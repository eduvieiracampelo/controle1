<div class="flex justify-between items-center mb-6">
  <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Tags</h1>
  <%= link_to "Nova Tag", new_tag_path, class: "bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700" %>
</div>

<div class="bg-white dark:bg-gray-800 rounded-lg shadow overflow-hidden">
  <table class="w-full">
    <thead class="bg-gray-50 dark:bg-gray-700">
      <tr>
        <th class="px-4 py-3 text-left text-sm font-medium text-gray-500 dark:text-gray-300">Nome</th>
        <th class="px-4 py-3 text-right text-sm font-medium text-gray-500 dark:text-gray-300">Ações</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
      <% @tags.each do |tag| %>
        <tr class="hover:bg-gray-50 dark:hover:bg-gray-700">
          <td class="px-4 py-3">
            <span class="inline-flex items-center px-2 py-1 rounded bg-gray-100 dark:bg-gray-700 text-sm font-medium text-gray-900 dark:text-gray-100">
              <%= tag.name %>
            </span>
          </td>
          <td class="px-4 py-3 text-right">
            <%= link_to "Editar", edit_tag_path(tag), class: "text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 text-sm" %>
            <%= link_to "Excluir", tag, method: :delete, data: { confirm: "Tem certeza?" }, class: "text-red-600 dark:text-red-400 hover:text-red-800 dark:hover:text-red-300 text-sm ml-3" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<% if @tags.empty? %>
  <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-8 text-center text-gray-500 dark:text-gray-400">
    Nenhuma tag cadastrada. <%= link_to "Clique aqui", new_tag_path, class: "text-blue-600 dark:text-blue-400" %> para criar a primeira.
  </div>
<% end %>
